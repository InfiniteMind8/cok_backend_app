# ─── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed origins for CORS (frontend URLs). Include
# both localhost during dev and the production domain post-deploy.
CORS_ORIGINS=http://localhost:3000

# ─── Database (Postgres / Supabase) ────────────────────────────────────────────
# Both URLs MUST point at the SAME Supabase project. DATABASE_URL uses port
# 6543 (transaction pooler — runtime). DIRECT_URL uses port 5432 (session
# pooler — migrations + advisory locks).
DATABASE_URL=
DIRECT_URL=

# ─── Auth (Clerk backend SDK) ──────────────────────────────────────────────────
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# JWT issuer (Clerk frontend's instance URL). Used to verify JWTs.
# Find it under Clerk dashboard → API Keys → "Frontend API URL".
CLERK_JWT_ISSUER=

# ─── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL="City of Karis <noreply@cityofkaris.example>"

# ─── Storage (S3-compatible: AWS S3 / R2 / B2) ────────────────────────────────
STORAGE_DRIVER=local
STORAGE_ENCRYPTION_KEY=
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# ─── Observability (Sentry) ────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENV=development

# ─── Rate limiting (Upstash Redis; in-memory fallback if unset — dev only) ─────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron (shared secret for /cron/* protected endpoints) ──────────────────────
CRON_SECRET=

# ─── App-level config ──────────────────────────────────────────────────────────
IMPORT_MAX_ROWS=1000
